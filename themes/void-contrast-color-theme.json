    "tab.activeForeground": "#ffffff",
    "tab.inactiveForeground": "#555555",
    "tab.unfocusedActiveForeground": "#999999",
    "tab.unfocusedInactiveForeground": "#555555",
    "tab.border": "#00000000",
    "tab.activeBorder": "#00000000",
    "tab.activeBorderTop": "#3EB4FF",
