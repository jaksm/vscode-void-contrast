    "editorGroupHeader.tabsBorder": "#00000000",
    "editorGroupHeader.border": "#00000000",
    "editorGroup.border": "#1a1a1a",

    "breadcrumb.background": "#000000",
    "breadcrumb.foreground": "#666666",
    "breadcrumb.focusForeground": "#cccccc",
    "breadcrumb.activeSelectionForeground": "#ffffff",

    "input.background": "#080808",
    "input.border": "#242424",
    "input.foreground": "#FFFFFF",
    "input.placeholderForeground": "#444444",
    "inputOption.activeBackground": "#3EB4FF30",
    "inputOption.activeBorder": "#3EB4FF",
    "inputOption.activeForeground": "#FFFFFF",
    "inputValidation.errorBackground": "#1A0000",
    "inputValidation.errorBorder": "#8B0000",
    "inputValidation.errorForeground": "#f44747",
    "inputValidation.infoBackground": "#0a0a2a",
    "inputValidation.infoBorder": "#264f78",
